# TrustBite Backend — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# ── Database ────────────────────────────────────────────────────────────────
# PostgreSQL (Neon, Supabase, Railway, etc.) or sqlite:/// for local dev
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── JWT Security ─────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-this-with-a-random-64-char-hex-string
ALGORITHM=HS256

# ── Token Expiry ─────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Password Hashing ──────────────────────────────────────────────────────────
# bcrypt work factor — increase as hardware improves (12 is good for 2025)
BCRYPT_ROUNDS=12

# ── Runtime ──────────────────────────────────────────────────────────────────
# Set to "production" on any deployed environment
ENVIRONMENT=development
DEBUG=false

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Email (for verification + password reset) ────────────────────────────────
# Leave blank to use console-print fallback in development
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAILS_FROM_NAME=TrustBite
EMAILS_FROM_EMAIL=no-reply@trustbite.com
FRONTEND_URL=http://localhost:5173
